{
  "Notion": {
    "color": {
      "surface": {
        "$type": "color",
        "$value": "#ffffff",
        "$description": "Notion paper surface and card background.",
        "$extensions": { "com.echo.brandMigration": { "status": "mapped", "rawBrandValue": "#ffffff" } }
      },
      "canvasSoft": {
        "$type": "color",
        "$value": "#f6f5f4",
        "$description": "Warm off-white page canvas.",
        "$extensions": { "com.echo.brandMigration": { "status": "mapped", "rawBrandValue": "#f6f5f4" } }
      },
      "ink": {
        "$type": "color",
        "$value": "#000000",
        "$description": "Near-black primary type.",
        "$extensions": { "com.echo.brandMigration": { "status": "mapped", "rawBrandValue": "#000000" } }
      },
      "primaryAction": {
        "$type": "color",
        "$value": "#0075de",
        "$description": "Single confident blue for primary CTA and links.",
        "$extensions": { "com.echo.brandMigration": { "status": "mapped", "rawBrandValue": "#0075de" } }
      },
      "stickerPalette": {
        "$type": "color",
        "$value": "#62aef0",
        "$description": "Representative sticker accent; full palette belongs to demo-only visual controls.",
        "$extensions": { "com.echo.brandMigration": { "status": "style-only", "rawBrandValue": ["#62aef0", "#d6b6f6", "#ff64c8", "#dd5b00", "#2a9d99", "#1aae39"] } }
      }
    },
    "radius": {
      "card": {
        "$type": "dimension",
        "$value": { "value": 12, "unit": "px" },
        "$description": "Main card radius.",
        "$extensions": { "com.echo.brandMigration": { "status": "mapped", "echoCandidate": "Radius/Medium" } }
      },
      "pill": {
        "$type": "dimension",
        "$value": { "value": 9999, "unit": "px" },
        "$description": "Pill buttons and badges.",
        "$extensions": { "com.echo.brandMigration": { "status": "style-only", "reason": "Not a fixed primitive radius." } }
      }
    },
    "$extensions": {
      "componentMapping": "component-mapping.json"
    }
  }
}
