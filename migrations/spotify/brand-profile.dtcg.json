{
  "$description": "Spotify-ish 第三个 demo 的 DTCG 风格迁移资产。token 部分按 DTCG 表达；component pattern 只作为 group metadata，完整组件映射见 component-mapping.json。",
  "$extensions": {
    "com.echo.asset": {
      "assetVersion": "0.1.0",
      "brand": "spotify",
      "statusValues": ["mapped", "fallback", "style-only", "missing", "ask-user"]
    },
    "com.echo.sources": {
      "brandSource": "current demo Spotify-ish style preset",
      "evidence": "migrations/spotify/brand-evidence.json",
      "dangouiSchema": "data/dangoui.design-system.json"
    }
  },
  "Color": {
    "PageBackground": {
      "$type": "color",
      "$value": "#121212",
      "$extensions": {
        "com.echo.brandMigration": {
          "status": "mapped",
          "target": "--du-bg-2",
          "reason": "深色页面底色在 demo 抽样中占比最高，承接为页面背景。"
        }
      }
    },
    "Surface": {
      "$type": "color",
      "$value": "#181818",
      "$extensions": {
        "com.echo.brandMigration": {
          "status": "mapped",
          "target": "--du-bg-1",
          "reason": "卡片和内容容器使用更浅一级深色，承接为主表面。"
        }
      }
    },
    "TextPrimary": {
      "$type": "color",
      "$value": "#ffffff",
      "$extensions": {
        "com.echo.brandMigration": {
          "status": "mapped",
          "target": "--du-text-1",
          "reason": "暗底一级文字需要高对比白色。"
        }
      }
    },
    "TextSecondary": {
      "$type": "color",
      "$value": "#b3b3b3",
      "$extensions": {
        "com.echo.brandMigration": {
          "status": "mapped",
          "target": "--du-text-3",
          "reason": "元信息和辅助文字使用低对比灰色。"
        }
      }
    },
    "PrimaryAction": {
      "$type": "color",
      "$value": "#1ed760",
      "$extensions": {
        "com.echo.brandMigration": {
          "status": "mapped",
          "target": "--du-primary-color / --du-primary-solid-bg",
          "reason": "绿色稳定承担行动入口和品牌强调。"
        }
      }
    },
    "PrimarySoftBackground": {
      "$type": "color",
      "$value": "#153b25",
      "$extensions": {
        "com.echo.brandMigration": {
          "status": "mapped",
          "target": "--du-primary-soft-bg",
          "reason": "作为暗色模式下的品牌柔和背景。"
        }
      }
    }
  },
  "Radius": {
    "Card": {
      "$type": "dimension",
      "$value": { "value": 12, "unit": "px" },
      "$extensions": {
        "com.echo.brandMigration": {
          "status": "mapped",
          "currentToken": "Radius/Medium",
          "currentSourceType": "number",
          "rawBrandValue": "12px",
          "reason": "当前 Echo primitives 中 Radius/Medium = 12，可以准确承接卡片圆角。"
        }
      }
    },
    "Control": {
      "$type": "dimension",
      "$value": { "value": 999, "unit": "px" },
      "$extensions": {
        "com.echo.brandMigration": {
          "status": "fallback",
          "currentToken": null,
          "futureTokenCandidate": "Radius/Pill",
          "rawBrandValue": "999px",
          "reason": "当前 primitives 没有 pill radius，demo 先通过 adapter 落到 --style-control-radius。"
        }
      }
    }
  },
  "Shadow": {
    "$description": "当前 Echo primitives 和 dangoui 未确认 shadow token，不创建空 shadow token。",
    "$extensions": {
      "com.echo.brandMigration": {
        "status": "style-only",
        "rawBrandValue": "0 18px 42px rgba(0,0,0,.36)",
        "futureTokenCandidate": "Shadow/CardDarkElevated",
        "reason": "暗色媒体卡片需要厚重阴影，但当前只能作为 demo style 控制。"
      }
    }
  },
  "Components": {
    "$description": "组件不是 DTCG 标准 token 类型。这里只保留摘要，完整映射见 component-mapping.json。",
    "$extensions": {
      "com.echo.brandMigration": {
        "patterns": ["dark-media-card", "pill-primary-action", "dark-form-control", "progress-feedback"]
      }
    }
  }
}
